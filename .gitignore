# 依赖包（体积巨大，绝对不能传）
node_modules/
/dist/
/.next/
/out/

# 本地环境变量配置文件（包含密钥，严禁上传）
.env
.env.local
.env.development.local
.env.production.local

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 编译后的字节码
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境（绝对不能上传）
venv/
.venv/
env/
ENV/

# Jupyter Notebook 检查点
.ipynb_checkpoints/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# IntelliJ IDEA / WebStorm / PyCharm
.idea/
*.iws
*.iml
*.ipr

# 操作系统特有文件
.DS_Store
Thumbs.db